rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin UID allowed to write matches
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'EAi3lYhlSFYGaqm9F87BdJb1Vrg1';
    }

    // MATCHES — public read, admin write only
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // USERS — each user can only read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // PREDICTIONS — signed-in users can read all predictions,
    // but can only create/update/delete their own
    match /predictions/{predictionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
